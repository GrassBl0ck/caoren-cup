{
  "version": 2,
  "description": "Caoren Cup web audio manifest. Put BGM files in music/ and SFX files in sfx/, then update the src paths here.",
  "defaults": {
    "masterVolume": 0.75,
    "bgmVolume": 0.42,
    "sfxVolume": 0.85,
    "musicTrack": "common_bgm_01"
  },
  "music": [
    {
      "id": "common_bgm_01",
      "title": "统一 BGM 01",
      "src": "/assets/audio/music/common-bgm-01.mp3",
      "loop": true
    },
    {
      "id": "common_bgm_02",
      "title": "统一 BGM 02",
      "src": "/assets/audio/music/common-bgm-02.mp3",
      "loop": true
    }
  ],
  "sfx": {
    "adminPrompt": {
      "title": "管理员提示音",
      "src": "/assets/audio/sfx/admin-prompt.mp3",
      "forceVolume": 1
    },
    "phaseChange": {
      "title": "阶段切换",
      "src": "/assets/audio/sfx/phase-change.mp3"
    },
    "draftPick": {
      "title": "完成一次选人",
      "src": "/assets/audio/sfx/draft-pick.mp3"
    },
    "mapBan": {
      "title": "完成一次地图 Ban",
      "src": "/assets/audio/sfx/map-ban.mp3"
    },
    "sidePick": {
      "title": "完成最终选边",
      "src": "/assets/audio/sfx/side-pick.mp3"
    },
    "roleReveal": {
      "title": "身份公布",
      "src": "/assets/audio/sfx/role-reveal.mp3"
    },
    "matchEnd": {
      "title": "比赛结束",
      "src": "/assets/audio/sfx/match-end.mp3"
    },
    "notification": {
      "title": "普通提示",
      "src": "/assets/audio/sfx/notification.mp3"
    }
  }
}
